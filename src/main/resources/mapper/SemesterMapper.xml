<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.niuniu.mapper.SemesterMapper">

    <!-- 结果映射：实体类属性 → 数据库字段名 -->
    <resultMap id="SemesterResultMap" type="com.niuniu.pojo.Semester">
        <id property="id" column="id"/>
        <result property="semesterName" column="semester_name"/>
        <result property="semesterCode" column="semester_code"/>
        <result property="startDate" column="start_date"/>
        <result property="endDate" column="end_date"/>
        <result property="isCurrent" column="is_current"/>
        <result property="createTime" column="create_time"/>
        <result property="updateTime" column="update_time"/>
    </resultMap>

    <!-- 查询所有学期 -->
    <select id="selectAll" resultMap="SemesterResultMap">
        SELECT id, semester_name, semester_code, start_date, end_date, 
               is_current, create_time, update_time
        FROM semesters
        ORDER BY semester_code DESC
    </select>

    <!-- 根据ID查询学期 -->
    <select id="selectById" resultMap="SemesterResultMap">
        SELECT id, semester_name, semester_code, start_date, end_date, 
               is_current, create_time, update_time
        FROM semesters
        WHERE id = #{id}
    </select>

    <!-- 根据学期代码查询学期 -->
    <select id="selectByCode" resultMap="SemesterResultMap">
        SELECT id, semester_name, semester_code, start_date, end_date, 
               is_current, create_time, update_time
        FROM semesters
        WHERE semester_code = #{semesterCode}
    </select>

</mapper>

